import os

configfile: "config.yaml"
FIELD = config['FIELD']
CUBE = str(config['CUBE'])
DATA = str(config['PATH_TO_DATA'])
SOFTWARE = str(config['PATH_TO_SOFTWARE'])
CBEAMS = str(config['PATH_TO_CBEAMS'])

beams, = glob_wildcards(DATA+"/"+FIELD+"/HI_B0{xx}_cube"+CUBE+"_image.fits")

wildcard_constraints:
    beams="\d+"

rule all:
    input:
        DATA+"/mos_"+FIELD+"/cleanup_cube"+CUBE+".txt"

rule make_bin_mask_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask.fits"
    output:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin.fits"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/binary_mask.py -t "+FIELD+" -c "+CUBE+" -j "+str(workflow.cores)

rule dilate_mask_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin.fits"
    output:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin_dil.fits"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/dilate_binmask.py -t "+FIELD+" -c "+CUBE+" -j "+str(workflow.cores)

rule sofia_final_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin_dil.fits"
    output:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cat.txt",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cat.xml",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_mask-2d.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_mask.fits"
    shell:
        "rm -rf "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cubelets/; "
        "sofia "+SOFTWARE+"/aper_sf2/sofia_final_template.par input.data={input[0]} input.mask={input[1]}"

rule add_beam2source_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cat.txt"
    output:
        DATA+"/mos_"+FIELD+"/final_beam2source_cube"+CUBE+".txt"
    shell:
        "python3 "+SOFTWARE+"/aper_cube_stack/modules/beam2source.py -c "+CUBE+" -f {input} -p "+CBEAMS+" -d "+DATA+"; "
        "touch {output}"

rule generate_specfull_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cat.xml"
    output:
        DATA+"/mos_"+FIELD+"/final_specfull_cube"+CUBE+".txt"
    shell:
        "rm -rf "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_figures/; "
        "python3 "+SOFTWARE+"/aper_sf2/src/get_specfull.py -t "+FIELD+" -c "+CUBE+"; "
        "touch {output}"

rule run_sip_fullres:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_cat.xml",
        DATA+"/mos_"+FIELD+"/final_beam2source_cube"+CUBE+".txt",
        DATA+"/mos_"+FIELD+"/final_specfull_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sip_cube"+CUBE+".txt"
    shell:
        "sofia_image_pipeline -c {input[0]} -s panstarrs 'DSS2 Blue' 'GALEX Near UV' -i 5 -m; "
        "touch {output}"

rule edit_sip_figs_fullres:
    input:
        DATA+"/mos_"+FIELD+"/final_sip_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sip_cube"+CUBE+"_edit.txt"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/edit_sip_images.py -t "+FIELD+" -c "+CUBE+"; "
        "touch {output}"

rule rename_pngs_fullres:
    input:
        DATA+"/mos_" + FIELD + "/final_sip_cube"+CUBE+"_edit.txt"
    output:
        DATA+"/mos_" + FIELD + "/final_rename_cube"+CUBE+".txt"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/rename_combo.py -t " + FIELD + " -c "+CUBE+"; "
        "touch {output}"

rule dilate_mask_smooth:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin_dil.fits"
    output:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin_dil_sm.fits"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/dilate_binmask.py -t "+FIELD+" -c "+CUBE+" -f {input[1]} -s sm -j "+str(workflow.cores)

rule sofia_final_smooth:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask_bin_dil_sm.fits"
    output:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.txt",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.xml",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_mask-2d.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_mask.fits"
    shell:
        "sofia "+SOFTWARE+"/aper_sf2/sofia_final_template.par input.data={input[0]} input.mask={input[1]}"

rule add_beam2source_smooth:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sm_beam2source_cube"+CUBE+".txt"
    shell:
        "python3 "+SOFTWARE+"/aper_cube_stack/modules/beam2source.py -c "+CUBE+" -f {input} -p "+CBEAMS+" -d "+DATA+"; "
        "touch {output}"

rule generate_full_spec_smooth:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image.fits",
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.xml"
    output:
        DATA+"/mos_"+FIELD+"/final_sm_specfull_cube"+CUBE+".txt"
    shell:
        "rm -rf "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_figures/; "
        "python3 "+SOFTWARE+"/aper_sf2/src/get_specfull.py -t "+FIELD+" -c "+CUBE+" -p sm; "
        "touch {output}"

rule run_sip_smooth:
    input:
        DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.xml",
        DATA+"/mos_"+FIELD+"/final_sm_beam2source_cube"+CUBE+".txt",
        DATA+"/mos_"+FIELD+"/final_sm_specfull_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sm_sip_cube"+CUBE+".txt"
    shell:
        "sofia_image_pipeline -c {input[0]} -s panstarrs -i 5 -m; "
        "touch {output}"

rule edit_sip_figs_smooth:
    input:
        DATA+"/mos_"+FIELD+"/final_sm_sip_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sm_sip_cube"+CUBE+"_edit.txt"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/edit_sip_images.py -t "+FIELD+" -c "+CUBE+" -w; "
        "touch {output}"

rule rename_pngs_smooth:
    input:
        DATA+"/mos_"+FIELD+"/final_sm_sip_cube"+CUBE+"_edit.txt"
    output:
        DATA+"/mos_"+FIELD+"/final_sm_rename_cube"+CUBE+".txt"
    shell:
        "python3 "+SOFTWARE+"/aper_sf2/src/rename_combo.py -t "+FIELD+" -c "+CUBE+" -p sm -w; "
        "touch {output}"

rule clean_up:
    input:
        DATA+"/mos_"+FIELD+"/final_beam2source_cube"+CUBE+".txt",
        DATA+"/mos_"+FIELD+"/final_rename_cube"+CUBE+".txt",
        DATA+"/mos_"+FIELD+"/final_sm_beam2source_cube"+CUBE+".txt",
        DATA+"/mos_"+FIELD+"/final_sm_rename_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/cleanup_cube"+CUBE+".txt"
    shell:
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0*_cube"+CUBE+"_pb.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0*_cube"+CUBE+"_spline.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0*_cube"+CUBE+"_spline_clean_pb.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0*_cube"+CUBE+"_spline_clean_smooth_pb.fits; "
        "rm -rf "+DATA+"/mos_"+FIELD+"/*filtered.fits; "
        "rm -rf "+DATA+"/mos_"+FIELD+"/*filtered_spline.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_mask.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_mask.fits; "
        "touch {output}"
