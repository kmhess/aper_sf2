        "mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.xml"
    output:
        "mos_"+FIELD+"/final_sm_specfull_cube"+CUBE+".txt"
    shell:   # ADD PREFIX OPTION HERE!  Done?  Unnecessary?
        "rm -rf mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_figures/; "
        "python3 ../scratch/stuff/aper_sf2/src/get_specfull.py -t "+FIELD+" -c "+CUBE+" -p sm; "
        "touch {output}"

rule run_sip_smooth:
    input:
        "mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_cat.xml",
        # "mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image.fits",
        "mos_"+FIELD+"/final_sm_specfull_cube"+CUBE+".txt"
    output:
        "mos_"+FIELD+"/final_sm_sip_cube"+CUBE+".txt"
    shell:
        "sofia_image_pipeline -c {input[0]} -s panstarrs -i 5 -m; "
        #"sofia_image_pipeline -c {input[0]} -s 'DSS2 Blue' 'GALEX Near UV' -i 5 -m; "
        "touch {output}"

rule edit_sip_figs_smooth:
    input:
        "mos_"+FIELD+"/final_sm_sip_cube"+CUBE+".txt"
    output:
        "mos_"+FIELD+"/final_sm_sip_cube"+CUBE+"_edit.txt"
    shell:
        "python3 ../scratch/stuff/aper_sf2/src/edit_sip_images.py -t "+FIELD+" -c "+CUBE+" -w; "
        "touch {output}"

rule rename_pngs_smooth:
    input:
        "mos_" + FIELD + "/final_sm_sip_cube"+CUBE+"_edit.txt"
    output:
        "mos_" + FIELD + "/final_sm_rename_cube"+CUBE+".txt"
    shell:  # ADD PREFIX OPTION HERE! Done
        "python3 ../scratch/stuff/aper_sf2/src/rename_combo.py -t " + FIELD + " -c "+CUBE+" -p sm -w; "
        "touch {output}"

rule clean_up:
    input:
        "mos_" + FIELD + "/final_rename_cube"+CUBE+".txt"
        "mos_" + FIELD + "/final_sm_rename_cube"+CUBE+".txt"
    output:
        DATA+"/mos_"+FIELD+"/cleanup_cube"+CUBE+".txt"
    shell:
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0{bm}_cube"+CUBE+"_pb.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0{bm}_cube"+CUBE+"_spline.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0{bm}_cube"+CUBE+"_spline_clean_pb.fits; "
        "rm -rf "+DATA+"/"+FIELD+"/HI_B0{bm}_cube"+CUBE+"_spline_clean_smooth_pb.fits; "
        "rm -rf "+DATA+"/mos_"+FIELD+"/*filtered.fits; "
        "rm -rf "+DATA+"/mos_"+FIELD+"/*filtered_spline.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_image_sofiaFS_mask.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_image_mask.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_noise.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_weights.fits; "
        "fpack "+DATA+"/mos_"+FIELD+"/"+FIELD+"_HIcube"+CUBE+"_clean_smooth_image_mask.fits; "
        "touch {output}"
